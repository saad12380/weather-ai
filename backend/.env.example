# ==============================================
# WEATHER AI PLATFORM - ENVIRONMENT CONFIGURATION
# ==============================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env file to version control

# ============ DEPLOYMENT ENVIRONMENT ============
# Options: development, staging, production
ENVIRONMENT=development

# ============ SERVER CONFIGURATION ============
# Backend server port
BACKEND_PORT=3000

# Frontend URL (where your frontend is hosted)
# Example: https://weatherai.com (production) or http://localhost:3000 (development)
WEBSITE_URL=http://localhost:3000

# API base URL
# Example: https://api.weatherai.com (production) or http://localhost:3000 (development)
API_URL=http://localhost:3000/api

# ============ SECURITY KEYS ============
# JWT Secret Key - Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# IMPORTANT: Use a strong, random value in production
# Change this immediately before going live
SECRET_KEY=generate-your-own-key-here

# Session Secret Key - Generate a new one for production
# python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET_KEY=your-session-secret-key-change-in-production

# ============ EXTERNAL API KEYS ============
# OpenWeatherMap API Key
# Get from: https://openweathermap.org/api
OPENWEATHER_API_KEY=your-openweather-api-key

# ============ DATABASE CONFIGURATION ============
# SQLite path (for development/small deployments)
# For production, use PostgreSQL instead
DATABASE_URL=sqlite:///./weather.db

# Production Database Configuration (PostgreSQL)
# Example: postgresql://user:password@host:port/dbname
# Uncomment and use this for production:
# DATABASE_URL=postgresql://user:password@prod-db-host:5432/weather_ai

# ============ EMAIL CONFIGURATION ============
# SMTP Server configuration for sending emails
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# Email account credentials
# For Gmail: Use App Password (not your regular password)
# See: https://myaccount.google.com/apppasswords
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# From email address (can be same as SMTP_USERNAME)
EMAIL_FROM=your-email@gmail.com

# Admin email for receiving contact form submissions
ADMIN_EMAIL=admin@your-domain.com

# ============ REDIS CONFIGURATION (Optional) ============
# Redis URL for caching and session management
# Example: redis://localhost:6379
REDIS_URL=redis://localhost:6379

# ============ FEATURE FLAGS ============
# Enable/Disable features
ENABLE_CACHE=true
ENABLE_NOTIFICATIONS=true
ENABLE_WEBSOCKET=true
ENABLE_DYNAMIC_THRESHOLDS=true

# ============ OAUTH CONFIGURATION ============
# Google OAuth (Get from: https://console.cloud.google.com/)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
MICROSOFT_CLIENT_ID=your-microsoft-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret

# ============ PRODUCTION CONFIGURATION ============
# HTTPS enabled (always true in production)
HTTPS_ENABLED=false

# CORS origins (comma-separated for production)
# Example: https://weatherai.com,https://www.weatherai.com,https://api.weatherai.com
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ============ LOGGING ============
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log file path (optional)
# LOG_FILE=/var/log/weather-ai/backend.log

# ============ RATE LIMITING ============
# Rate limit requests per minute (for public endpoints)
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60

# ============ MONITORING & ANALYTICS ============
# Enable/disable monitoring features
ENABLE_MONITORING=true

# Optional: Sentry DSN for error tracking
# Get from: https://sentry.io/
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
